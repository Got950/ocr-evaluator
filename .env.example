# ============================================================
# Database
# ============================================================
# PostgreSQL connection string (asyncpg for web, psycopg2 auto-converted for Celery/Alembic)
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@localhost:5432/ocr_evaluator

# ============================================================
# Redis / Celery
# ============================================================
# Redis URL for Celery task queue (optional — without it, grading runs in-process)
REDIS_URL=redis://localhost:6379/0

# ============================================================
# S3 / MinIO
# ============================================================
# Object storage for PDF uploads (optional — without S3_BUCKET, files go to local UPLOAD_DIR)
# S3_BUCKET=ocr-evaluator-uploads
# S3_ENDPOINT_URL=http://localhost:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# S3_REGION=us-east-1

# ============================================================
# Auth (JWT)
# ============================================================
# Secret key for signing JWT tokens — MUST change in production (min 32 chars)
SECRET_KEY=change-me-in-production-min-32-chars!!
# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================================
# OCR / AI
# ============================================================
# Master switch: set to false for safe/manual-review mode (OCR runs, grading skipped)
AI_GRADING_ENABLED=true
# Max parallel OCR+grading tasks (limits GPU/CPU contention)
MAX_CONCURRENT_EVALUATIONS=4
# Optional custom hard-level rubric evaluator import path (e.g. "mymodule.MyEvaluator")
# HARD_RUBRIC_EVALUATOR=

# ============================================================
# App
# ============================================================
# Environment: "dev" auto-runs Alembic migrations on startup; "production" does not
ENVIRONMENT=dev
# Structured log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Enable per-IP submission rate limiting
ENABLE_RATE_LIMITING=true
# Local directory for PDF uploads when S3 is not configured
UPLOAD_DIR=uploads
# Max upload file size in bytes (default 8 MB)
MAX_UPLOAD_SIZE_BYTES=8388608
# Comma-separated allowed hosts for TrustedHostMiddleware (* = all)
TRUSTED_HOSTS=*
# Comma-separated CORS origins (leave empty to disable CORS)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Add security headers (nosniff, frame deny, referrer policy)
ENABLE_SECURITY_HEADERS=true
# Minimum response size in bytes before gzip kicks in
GZIP_MINIMUM_SIZE=1000
